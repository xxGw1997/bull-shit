{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@cyper-me/agent": ["packages/agent/src/index.ts"],
      "@cyper-me/agent/embeddings": ["packages/agent/src/embeddings/index.ts"],
      "@cyper-me/database": ["packages/database/src/index.ts"],
      "@cyper-me/shared": ["packages/shared/src/index.ts"],
      "@cyper-me/vector-store-chroma": ["packages/vector-store-chroma/src/index.ts"]
    },
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["bun"]
  }
}
