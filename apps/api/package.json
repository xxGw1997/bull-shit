    "@cyper-me/shared": "workspace:*",
    "@cyper-me/vector-store-chroma": "workspace:*",
    "@elysiajs/cors": "1.4.2",
    "@elysiajs/openapi": "^1.4.15",
    "drizzle-orm": "0.45.2",
    "elysia": "1.4.29"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  }
}
